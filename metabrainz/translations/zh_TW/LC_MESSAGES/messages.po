#~ msgid ""
#~ "The MetaBrainz Foundation will not "
#~ "collect any private information unless\n"
#~ "    you choose to donate to "
#~ "support the MusicBrainz project. Any "
#~ "personal\n"
#~ "    information you choose to provide"
#~ " during the donation process will not"
#~ " be\n"
#~ "    revealed to anyone else, unless "
#~ "you give us permission to list "
#~ "your name on\n"
