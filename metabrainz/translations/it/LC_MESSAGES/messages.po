#: metabrainz/templates/index/team.html:12
#, fuzzy
msgid "<span class=\"name\">Robert Kaye</span> &mdash; Founder"
msgstr "<span class=\"name\">Robert Kaye</span> &mdash; Direttore esecutivo"

#: metabrainz/templates/index/team.html:14
#, fuzzy, python-format
msgid ""
