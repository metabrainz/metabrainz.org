{
  "name": "metabrainz.org",
  "version": "0.0.0",
  "description": "package.json for keeping track of nodejs dependencies for MetaBrainz website",
  "author": "MetaBrainz Foundation Inc.",
  "license": "GPL-2.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/metabrainz/metabrainz.org.git"
  },
  "bugs": {
    "url": "https://tickets.metabrainz.org/projects/MeB"
  },
  "homepage": "https://metabrainz.org",
  "scripts": {
    "build:dev": "webpack --mode=development --watch --progress --color",
    "build:prod": "webpack --mode=production --no-watch --color",
    "build:i18n": "node frontend/js/scripts/build-translations.mjs",
    "build:less": "lessc ./frontend/css/main.less > ./frontend/css/main.css",
    "build:types": "tsc --emitDeclarationOnly",
    "build": "npm run build:dev",
    "lint:js": "eslint ./frontend/js/src --fix --quiet",
    "lint:less": "stylelint --fix './frontend/css/*.less'",
    "lint:js:ci": "eslint ./frontend/js/src --max-warnings 0 --color",
    "lint:less:ci": "stylelint './frontend/css/*.less'",
    "format": "npm run lint:js; npm run lint:less",
    "format:ci": "npm run lint:js:ci; npm run lint:less:ci",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.7",
    "@types/lodash": "^4.17.24",
    "core-js": "^3.49.0",
    "formik": "^2.4.9",
    "i18next": "^26.3.1",
    "less": "^4.6.4",
    "less-plugin-clean-css": "^1.6.0",
    "lodash": "^4.18.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/plugin-transform-class-properties": "^7.29.7",
    "@babel/plugin-transform-runtime": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/parser": "^8.61.0",
    "@types/clean-css": "^4.2.11",
    "@types/less": "^3.0.8",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "babel-loader": "^10.1.1",
    "decode-uri-component": "^0.4.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-webpack-plugin": "^6.0.0",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "globals": "^17.6.0",
    "i18next-conv": "^16.0.0",
    "less-loader": "^13.0.0",
    "network-information-types": "^0.1.1",
    "postcss-less": "^6.0.0",
    "prettier": "^3.8.4",
    "stylelint": "^17.13.0",
    "stylelint-config-recommended-less": "^4.2.1",
    "stylelint-prettier": "^5.0.3",
    "stylelint-webpack-plugin": "^5.1.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "webpack-manifest-plugin": "^6.0.1"
  },
  "private": true
}
